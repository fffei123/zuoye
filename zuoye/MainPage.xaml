<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.MainPage"
             Title="垃圾分类指引">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1ABC9C" Offset="0"/>
            <GradientStop Color="#16A085" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    <VerticalStackLayout Padding="25" Spacing="25">

        <Label Text="垃圾分类指引"
               FontSize="30"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Button Text="查找附近垃圾桶"
                FontSize="18"
                BackgroundColor="#2ECC71"
                TextColor="White"
                HeightRequest="75"
                Clicked="GoToNearbyBinPage"/>

        <Button Text="扫码查询垃圾分类"
                FontSize="18"
                BackgroundColor="#3498DB"
                TextColor="White"
                HeightRequest="75"
                Clicked="GoToScanPage"/>

        <Button Text="垃圾分类指南"
                FontSize="18"
                BackgroundColor="#9B59B6"
                TextColor="White"
                HeightRequest="75"
                Clicked="GoToGuidePage"/>

        <Label Text="GPS 状态：已就绪"
               FontSize="16"
               HorizontalOptions="Center"
               Margin="0,20"/>

    </VerticalStackLayout>
</ContentPage>