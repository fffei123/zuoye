<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.ScanPage"
             Title="垃圾分类搜索">
    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry x:Name="SearchEntry"
               Placeholder="输入垃圾名称搜索，例如：塑料瓶、纸巾"
               FontSize="18"
               HeightRequest="50"/>

        <Button Text="开始搜索"
                BackgroundColor="#2D8B2D"
                TextColor="White"
                FontSize="18"
                HeightRequest="50"
                CornerRadius="12"
                Clicked="OnSearchClicked"/>

        <Frame BackgroundColor="#E8F5E8"
               CornerRadius="10"
               Padding="16"
               Margin="0,10">
            <Label x:Name="ResultLabel"
                   Text="搜索结果将显示在这里"
                   FontSize="18"
                   TextColor="#2D8B2D"/>
        </Frame>

        <Button Text="Back to Home"
                BackgroundColor="#EEEEEE"
                TextColor="#333333"
                FontSize="16"
                HeightRequest="55"
                CornerRadius="12"
                Clicked="GoBackToHome"/>

    </VerticalStackLayout>
</ContentPage>