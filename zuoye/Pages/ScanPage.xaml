<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.ScanPage"
             Title="Scan Sort Waste">

	<VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Start">

		<Label Text="Scan Waste for Sorting"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

		<Frame BorderColor="#333333"
               BackgroundColor="#F8F8F8"
               WidthRequest="260"
               HeightRequest="260"
               CornerRadius="12"
               HorizontalOptions="Center">
			<VerticalStackLayout VerticalOptions="Center">
				<Label Text="Camera Preview Area"
                       FontSize="16"
                       TextColor="#666666"
                       HorizontalOptions="Center"/>
				<Label Text="Place barcode inside the box"
                       FontSize="12"
                       TextColor="#999999"
                       HorizontalOptions="Center"
                       Margin="0,6"/>
			</VerticalStackLayout>
		</Frame>

		<Button Text="Start Scan"
                BackgroundColor="#007AFF"
                TextColor="White"
                FontSize="18"
                HeightRequest="65"
                CornerRadius="14"/>

		<Frame BackgroundColor="#E8F5E8"
               CornerRadius="10"
               Padding="16"
               Margin="0,10">
			<Label Text="Result: Plastic Bottle → Recyclable"
                   FontSize="18"
                   TextColor="#2D8B2D"/>
		</Frame>

		<Button Text="Back to Home"
                BackgroundColor="#EEEEEE"
                TextColor="#333333"
                FontSize="16"
                HeightRequest="55"
                CornerRadius="12"
                Clicked="GoBackToHome"/>

	</VerticalStackLayout>
</ContentPage>