<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.NearbyBinPage"
             Title="附近垃圾桶">

    <VerticalStackLayout Padding="25" Spacing="20" BackgroundColor="#E8E8E8">

        <Label Text="附近垃圾桶/回收点"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="Black"/>
        

        <Frame BackgroundColor="#FFFFFF" HeightRequest="220" CornerRadius="10">
            <Label Text="【地图预览区域】" HorizontalOptions="Center" VerticalOptions="Center" TextColor="Black"/>
        </Frame>

        <Label Text="GPS 位置：西安科技大学高新学院"
               FontSize="17"
               TextColor="Black"/>

        <CollectionView HeightRequest="220">
            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>1号垃圾桶（可回收）- 100米</x:String>
                    <x:String>2号垃圾桶（有害垃圾）- 150米</x:String>
                    <x:String>3号垃圾回收点 - 300米</x:String>
                </x:Array>
            </CollectionView.ItemsSource>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#FFFFFF" CornerRadius="8" Margin="0,10" Padding="10">
                        <Label Text="{Binding}" FontSize="17" TextColor="Black"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        
        <Button Text="返回首页" 
                Clicked="OnGoBackClicked"
                BackgroundColor="#4285F4"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>

    </VerticalStackLayout>
</ContentPage>