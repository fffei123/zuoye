<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.NearbyBinPage"
             Title="Nearby Bin Locations">

    <Grid>
        <Image Source="background.png"
               Aspect="AspectFill"
               Opacity="0.18"/>

        <VerticalStackLayout Padding="30" Spacing="20" BackgroundColor="Transparent">

            <Label Text="Nearby Rubbish Bins"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <Frame CornerRadius="14" Padding="0" BorderColor="Transparent" HeightRequest="240">
                <WebView x:Name="MapWebView" HeightRequest="240"/>
            </Frame>

            <Frame BackgroundColor="#E3F2FD" 
                   Padding="16" 
                   CornerRadius="10">
                <Label x:Name="lblGPS"
                       Text="Getting location..."
                       FontSize="17"
                       TextColor="#1976D2"/>
            </Frame>

            <Label Text="Bin List"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <CollectionView HeightRequest="240"
                            ItemsSource="{Binding BinList}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#FFFFFF" 
                               CornerRadius="10" 
                               Margin="0,6" 
                               Padding="14">
                            <Label Text="{Binding}" 
                                   FontSize="16" 
                                   TextColor="Black"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Back to Home"
                    BackgroundColor="#6200EE"
                    TextColor="White"
                    FontSize="16"
                    HeightRequest="55"
                    CornerRadius="12"
                    Clicked="GoBackHome"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>