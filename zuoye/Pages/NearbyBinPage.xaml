<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.NearbyBinPage"
             Title="Nearby Bin Locations">

    <Grid>
        <Image Source="background.png"
               Aspect="AspectFill"
               Opacity="0.18"/>

        <VerticalStackLayout Padding="30" Spacing="20" BackgroundColor="Transparent">

            <Label Text="Nearby Rubbish Bins"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <Frame BackgroundColor="#FFFFFF" 
                   HeightRequest="240" 
                   CornerRadius="14"
                   BorderColor="#DDDDDD">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Map Preview Area" 
                           FontSize="16" 
                           TextColor="#666666"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#E3F2FD" 
                   Padding="16" 
                   CornerRadius="10">
                <Label Text="Current GPS Location: Xi'an University"
                       FontSize="17"
                       TextColor="#1976D2"/>
            </Frame>

            <Label Text="Bin List"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <CollectionView HeightRequest="240">
                <CollectionView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>♻️ Recyclable Bin - 100m</x:String>
                        <x:String>☠️ Hazardous Bin - 150m</x:String>
                        <x:String>🗑️ General Waste Bin - 300m</x:String>
                    </x:Array>
                </CollectionView.ItemsSource>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#FFFFFF" 
                               CornerRadius="10" 
                               Margin="0,6" 
                               Padding="14">
                            <Label Text="{Binding}" 
                                   FontSize="16" 
                                   TextColor="Black"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Back to Home"
                    BackgroundColor="#6200EE"
                    TextColor="White"
                    FontSize="16"
                    HeightRequest="55"
                    CornerRadius="12"
                    Clicked="GoBackHome"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>