<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.GuidePage"
             Title="Waste Sorting Guide">

	<Grid>
		<Image Source="background.png" Aspect="AspectFill" Opacity="0.18"/>

		<ScrollView Padding="30" BackgroundColor="Transparent">
			<VerticalStackLayout Spacing="20">

				<Label Text="Waste Sorting Guide"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="Black"/>

				<Frame BackgroundColor="#D4A373" CornerRadius="14" Padding="18">
					<Label Text="Recyclable: Plastic, Glass, Paper, Metal" TextColor="White" FontSize="17"/>
				</Frame>

				<Frame BackgroundColor="#E9C46A" CornerRadius="14" Padding="18">
					<Label Text="Wet Waste: Leftovers, Fruit Peels, Plants" TextColor="White" FontSize="17"/>
				</Frame>

				<Frame BackgroundColor="#F4A261" CornerRadius="14" Padding="18">
					<Label Text="Dry Waste: Contaminated Paper, Disposable Cutlery" TextColor="White" FontSize="17"/>
				</Frame>

				<Frame BackgroundColor="#E76F51" CornerRadius="14" Padding="18">
					<Label Text="Hazardous: Batteries, Drugs, Cosmetics" TextColor="White" FontSize="17"/>
				</Frame>

				<Button Text="Back to Home"
                        BackgroundColor="#6200EE"
                        TextColor="White"
                        FontSize="16"
                        HeightRequest="55"
                        CornerRadius="12"
                        Clicked="GoBackHome"/>

			</VerticalStackLayout>
		</ScrollView>
	</Grid>
</ContentPage>