<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zuoye.GuidePage"
             Title="分类指南">

	<ScrollView Padding="25">
		<VerticalStackLayout Spacing="18">

			<Label Text="垃圾分类指南" FontSize="24" FontAttributes="Bold"/>

			<Border BackgroundColor="#D4A373" Padding="18" StrokeShape="RoundRectangle 8">
				<Label Text="可回收垃圾：塑料、玻璃、纸张、金属" TextColor="White" FontSize="17"/>
			</Border>

			<Border BackgroundColor="#E9C46A" Padding="18" StrokeShape="RoundRectangle 8">
				<Label Text="湿垃圾：剩菜、果皮、绿植" TextColor="White" FontSize="17"/>
			</Border>

			<Border BackgroundColor="#F4A261" Padding="18" StrokeShape="RoundRectangle 8">
				<Label Text="干垃圾：污染纸张、一次性餐具" TextColor="White" FontSize="17"/>
			</Border>

			<Border BackgroundColor="#E76F51" Padding="18" StrokeShape="RoundRectangle 8">
				<Label Text="有害垃圾：电池、药品、化妆品" TextColor="White" FontSize="17"/>
			</Border>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>